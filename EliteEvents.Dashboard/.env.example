# --- Local dev ---
# Single connection string for the Redis the C# EddnStreamReceiver writes to.
REDIS_URL=redis://localhost:6379

# --- Production (Docker / docker-compose) ---
# Instead of REDIS_URL, the container reads the password from a mounted secret
# file and takes host/port/TLS from these vars (see docker-compose.yaml).
# REDIS_HOST=private-elite-visitors-redis-do-user-18343723-0.d.db.ondigitalocean.com
# REDIS_PORT=25061
# REDIS_TLS=true
# REDIS_AUTH_FILE=/run/secrets/redis-auth